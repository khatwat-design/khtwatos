{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "dev:stack": "concurrently -c blue,magenta -n laravel,vite \"php artisan serve\" \"vite\"",
        "reverb": "php artisan reverb:start",
        "cap:sync": "node scripts/capacitor-prepare-webdir.mjs && npx cap sync android",
        "cap:sync:ios": "node scripts/capacitor-prepare-webdir.mjs && env DEVELOPER_DIR=${DEVELOPER_DIR:-/Applications/Xcode.app/Contents/Developer} npx cap sync ios",
        "cap:sync:all": "node scripts/capacitor-prepare-webdir.mjs && npx cap sync",
        "cap:copy": "npx cap copy",
        "cap:open:android": "npx cap open android",
        "cap:open:ios": "npx cap open ios",
        "cap:apk:debug": "export JAVA_HOME=\"${JAVA_HOME:-/Applications/Android Studio.app/Contents/jbr/Contents/Home}\" && export ANDROID_HOME=\"${ANDROID_HOME:-$HOME/Library/Android/sdk}\" && cd android && ./gradlew assembleDebug --no-daemon",
        "cap:android:apk": "npm run build && CAPACITOR_SERVER_URL=${CAPACITOR_SERVER_URL:-https://os.kharijm.com} npm run cap:sync && npm run cap:apk:debug"
    },
    "devDependencies": {
        "@inertiajs/vue3": "^2.0.0",
        "@tailwindcss/forms": "^0.5.3",
        "@types/node": "^25.6.2",
        "@vitejs/plugin-vue": "^5.2.1",
        "autoprefixer": "^10.4.12",
        "axios": "^1.7.9",
        "concurrently": "^9.0.1",
        "glob": "^10.4.5",
        "laravel-vite-plugin": "^1.2.0",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.4.17",
        "typescript": "^6.0.3",
        "vite": "^5.4.11",
        "vue": "^3.4.0",
        "vuedraggable": "^4.1.0"
    },
    "dependencies": {
        "@capacitor/android": "^6.2.1",
        "@capacitor/app": "^6.0.3",
        "@capacitor/cli": "^6.2.1",
        "@capacitor/core": "^6.2.1",
        "@capacitor/ios": "^6.2.1",
        "@capacitor/network": "^6.0.4",
        "@capacitor/push-notifications": "^6.0.5",
        "@capacitor/splash-screen": "^6.0.4",
        "@capacitor/status-bar": "^6.0.3",
        "laravel-echo": "^1.19.0",
        "pusher-js": "^8.5.0"
    }
}
