APP_NAME="خارج المخزون"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ─── Capacitor (غلاف الموبايل) ──────────────────────────────────────────────
# عنوان HTTPS لموقع Laravel (بدون شرطة أخيرة). يُستخدم في capacitor.config + index.html للغلاف.
# CAPACITOR_SERVER_URL=https://app.example.com
# مسار أول تحميل داخل التطبيق (جذر الموقع يوجّه ضيفًا لصفحة الدخول تلقائيًا إن وُجدت)
# CAPACITOR_LOGIN_PATH=/
# تصحيح WebView على أندرويد فقط (لا تستخدمه في الإنتاج)
# CAPACITOR_ANDROID_WEBVIEW_DEBUG=1

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=khtwatos
DB_USERNAME=khtwatos_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# نسخ احتياطي كامل من داخل التطبيق (قاعدة + storage المحلي؛ تشفير OpenSSL اختياري)
# BACKUP_DIRECTORY=backups
# BACKUP_MODE=full
# BACKUP_INCLUDE_PUBLIC_STORAGE=true
# BACKUP_INCLUDE_PRIVATE_STORAGE=true
# BACKUP_COMPRESS=true
# BACKUP_ENCRYPT=false
# BACKUP_ENCRYPTION_PASSWORD=
# BACKUP_OPENSSL_ITERATIONS=600000
# BACKUP_KEEP_MAX=30
# BACKUP_SCHEDULE_ENABLED=false
# BACKUP_SCHEDULE_AT=03:30
# BACKUP_MYSQLDUMP_PATH=mysqldump
# BACKUP_SQLITE3_PATH=sqlite3
# BACKUP_TAR_PATH=tar
# BACKUP_OPENSSL_PATH=openssl
#
# رفع النسخ إلى مستودع GitHub خاص (اختياري).
# BACKUP_GITHUB_PUSH_ENABLED=false
# BACKUP_GITHUB_TOKEN=
# BACKUP_GITHUB_OWNER=khatwat-design
# BACKUP_GITHUB_REPO=khtwatos-backups
# BACKUP_GITHUB_BRANCH=main
# BACKUP_GITHUB_SUBPATH=backups
# BACKUP_GITHUB_WORKDIR=
# BACKUP_DELETE_LOCAL_AFTER_GITHUB_PUSH=false

SESSION_DRIVER=database
# مدة الجلسة بالدقائق (عند الخمول). 43200 ≈ 30 يومًا — اضبط حسب سياسة الأمان لديك.
SESSION_LIFETIME=43200
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# دردشة الفريق: فورية عبر Reverb + Echo (شغّل: php artisan reverb:start)
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=1001
REVERB_APP_KEY=local-reverb-key
REVERB_APP_SECRET=local-reverb-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Calendly webhook HMAC signing key (optional in local; recommended in production)
CALENDLY_WEBHOOK_SIGNING_KEY=

# Web Push (PWA notifications)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@os.kharijm.com

# Firebase Cloud Messaging — مسار ملف JSON لحساب الخدمة (إشعارات تطبيق أندرويد/آيفون عبر Capacitor)
# FIREBASE_CREDENTIALS=/absolute/path/to/firebase-service-account.json
# على أندرويد ضع أيضًا ملف google-services.json من وحدة تحكم Firebase في android/app/ ثم أعد بناء APK (بدونه لا يعمل FCM في التطبيق).
# لا تضع true إلا بعد وجود google-services.json في بناء APK؛ وإلا قد يتعطل التطبيق بعد الموافقة على إذن الإشعارات.
# FIREBASE_MOBILE_PUSH_ENABLED=false

# Meta Ads sync (Warehouse)
META_ADS_APP_ID=
META_ADS_APP_SECRET=
META_ADS_REDIRECT_URI=
META_ADS_PORTAL_REDIRECT_URI=
META_ADS_PROFILE_REDIRECT_URI=
META_ADS_ACCESS_TOKEN=
META_ADS_GRAPH_VERSION=v22.0

# WhatsApp Cloud API (Outside module)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_GRAPH_VERSION=v22.0

# ---------------------------------------------------------------------------
# Instagram — قسم «الخارج» (Webhook + إرسال عبر Graph؛ OAuth من بوابة العميل = META_ADS_*)
# ---------------------------------------------------------------------------
# ويب هوك (نفس مسار واتساب): في Meta → Instagram → Webhooks
#   Callback URL = ${APP_URL}/outside/webhook   (مثال: https://os.kharijm.com/outside/webhook)
# اختياري: إن وُجد يُستخدم لتحقق ويب هوك إنستغرام؛ وإلا يُستخدم WHATSAPP_WEBHOOK_VERIFY_TOKEN
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=
# مرجع فقط (انسخه إلى Meta إن طُلب): لا يقرأه Laravel — للتوثيق والنسخ
INSTAGRAM_WEBHOOK_CALLBACK_URL="${APP_URL}/outside/webhook"
# معرّف تطبيق Instagram في لوحة Meta (أو اتركه فارغاً ليُستخدم META_ADS_APP_ID)
INSTAGRAM_APP_ID=
# المفتاح السري لمنتج Instagram إن اختلف عن META_ADS_APP_SECRET؛ وإلا اتركه فارغاً
INSTAGRAM_APP_SECRET=
# إصدار Graph لطلبات إرسال DM (افتراضياً = META_ADS_GRAPH_VERSION)
INSTAGRAM_GRAPH_VERSION=v22.0
# اختياري — رمز من Business Manager → مستخدم النظام → إنشاء رمز (صلاحيات رسائل إنستغرام). إن وُجد يُستخدم للإرسال بدل توكن بوابة العميل.
INSTAGRAM_ACCESS_TOKEN=
# معرّف Instagram Business Account لـ POST /{id}/messages (نفس entry.id في الويب هوك). يُفضَّل مع INSTAGRAM_ACCESS_TOKEN؛ وإلا يُؤخذ من تكامل العميل.
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# ---------------------------------------------------------------------------
# Messenger — قسم «الخارج» (Webhook object: page + إرسال عبر Graph)
# ---------------------------------------------------------------------------
# نفس مسار الويب هوك: Callback URL = ${APP_URL}/outside/webhook
# في Meta Developers → Webhooks → Page → اشترك في messages (أو حسب واجهة المنتج)
# رمز التحقق: MESSENGER_WEBHOOK_VERIFY_TOKEN أو نفس WHATSAPP_WEBHOOK_VERIFY_TOKEN
MESSENGER_WEBHOOK_VERIFY_TOKEN=
MESSENGER_GRAPH_VERSION=v22.0
# معرّف الصفحة التي تستقبل رسائل الماسنجر (entry.id في الويب هوك عادةً)
MESSENGER_PAGE_ID=
# رمز صفحة Page Access Token بصلاحية pages_messaging (إن وُجد يُستخدم للإرسال بدل توكن OAuth العميل)
MESSENGER_PAGE_ACCESS_TOKEN=

#
# إنستغرام (قسم الخارج): في Meta Developers → تطبيقك → Instagram → Webhooks
#   - Verify token: نفس WHATSAPP_WEBHOOK_VERIFY_TOKEN أو INSTAGRAM_WEBHOOK_VERIFY_TOKEN
#   - اشترك في object: instagram (وحقول messaging حسب واجهة Meta)
# ربط العميل: من بوابة العميل «ربط ميتا» يُخزَّن meta_instagram_account_id ويجب أن يطابق معرف حساب Instagram Business
# الظاهر في payload الويب هوك (entry.id) حتى تُربط الرسائل الواردة بالعميل وتعمل الردود من النظام.
# قالب Meta لبيانات دخول الموظفين (UTILITY/AUTHENTICATION) — متغيرات الجسم {{1}}…{{5}}: الاسم، اسم المستخدم، كلمة المرور، رابط الدخول، الدور
WHATSAPP_EMPLOYEE_CREDENTIALS_TEMPLATE=
WHATSAPP_EMPLOYEE_CREDENTIALS_LANG=ar

# تذكير مبيعات يومي لعملاء البضاعة (ساعة:دقيقة بتوقيت APP_TIMEZONE)
GOODS_DAILY_SALES_REMINDER_AT=09:00

VITE_APP_NAME="${APP_NAME}"
